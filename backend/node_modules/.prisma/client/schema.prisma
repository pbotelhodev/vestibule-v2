generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  TEACHER
  INSTITUTION
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DELETED
}

enum AuthProvider {
  GOOGLE
  LOCAL
}

enum StudentType {
  INDIVIDUAL
  INSTITUTIONAL
}

enum UserPlan {
  FREE
  PRO
  PREMIUM
}

/**
 * Schemas db
 */

/**
 * Schema User
 */

model User {
  id              String       @id @default(uuid())
  name            String
  email           String       @unique
  passwordHash    String?      @map("password_hash")
  role            UserRole     @default(STUDENT)
  activePlan      UserPlan     @default(FREE) @map("active_plan")
  status          UserStatus   @default(ACTIVE)
  authProvider    AuthProvider @default(LOCAL) @map("auth_provider")
  googleId        String?      @unique @map("google_id")
  studentType     StudentType  @default(INDIVIDUAL) @map("student_type")
  institutionCode String?      @map("institution_code")
  avatarUrl       String?      @map("avatar_url")
  phone           String?
  emailVerifiedAt DateTime?    @map("email_verified_at")
  lastLoginAt     DateTime?    @map("last_login_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  simulationResults StudentSimulationResult[]

  @@map("users")
}

/**
 * Schema Simulations
 */

enum SimulationSubject {
  MATEMATICA
  LINGUAS
  PORTUGUES
  LITERATURA
  INGLES
  ESPANHOL
  ARTES
  HISTORIA
  GEOGRAFIA
  BIOLOGIA
  FISICA
  QUIMICA
  CIENCIAS_HUMANAS
  CIENCIAS_NATUREZA
  GERAL
}

enum RequiredPlan {
  FREE
  PRO
  PREMIUM
}

enum Difficulty {
  EASY
  MODERATE
  DIFFICULT
  EXPERT
}

model Simulation {
  id              String            @id @default(uuid())
  publicId        String            @unique @map("public_id")
  title           String
  description     String
  difficulty      Difficulty        @default(EASY)
  subject         SimulationSubject
  originCode      String            @default("vest") @map("origin_code")
  requiredPlan    RequiredPlan      @default(FREE) @map("required_plan")
  timePerQuestion Int               @map("time_per_question")
  isPublished     Boolean           @default(false) @map("is_published")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  questions Question[]

  studentResults StudentSimulationResult[]

  @@map("simulations")
}

model Question {
  id           String @id @default(uuid())
  simulationId String @map("simulation_id")

  statement    String
  imageUrl     String? @map("image_url")
  imageAlt     String? @map("image_alt")
  imageCaption String? @map("image_caption")

  subject SimulationSubject
  topic   String?
  order   Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  simulation Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  alternatives             Alternative[]
  studentSimulationAnswers StudentSimulationAnswer[]

  @@map("questions")
}

model Alternative {
  id         String @id @default(uuid())
  questionId String @map("question_id")

  text      String?
  imageUrl  String? @map("image_url")
  imageAlt  String? @map("image_alt")
  isCorrect Boolean @default(false) @map("is_correct")
  order     Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  selectedInStudentAnswers StudentSimulationAnswer[] @relation("SelectedAlternativeOnStudentAnswer")
  correctInStudentAnswers  StudentSimulationAnswer[] @relation("CorrectAlternativeOnStudentAnswer")

  @@map("alternatives")
}

model StudentSimulationResult {
  id                     String            @id @default(uuid())
  studentId              String            @map("student_id")
  simulationId           String            @map("simulation_id")
  publicId               String            @map("public_id")
  title                  String
  subject                SimulationSubject
  totalQuestions         Int               @map("total_questions")
  correctAnswers         Int               @map("correct_answers")
  wrongAnswers           Int               @map("wrong_answers")
  percentage             Float
  score                  Float
  timePerQuestion        Int?              @map("time_per_question")
  timeSpentSeconds       Int               @map("time_spent_seconds")
  totalSimulationSeconds Int               @map("total_simulation_seconds")
  finishedAt             DateTime          @map("finished_at")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  student                User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  simulation             Simulation        @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  answers StudentSimulationAnswer[]

  @@unique([studentId, simulationId], map: "student_simulation_result_unique")
  @@index([studentId])
  @@index([simulationId])
  @@index([publicId])
  @@map("student_simulation_results")
}

model StudentSimulationAnswer {
  id String @id @default(uuid())

  resultId String @map("result_id")

  questionId            String?           @map("question_id")
  selectedAlternativeId String?           @map("selected_alternative_id")
  correctAlternativeId  String?           @map("correct_alternative_id")
  questionOrder         Int               @map("question_order")
  subject               SimulationSubject
  topic                 String?
  statement             String
  studentAnswerText     String?           @map("student_answer_text")
  correctAnswerText     String?           @map("correct_answer_text")
  studentAnswerOrder    Int?              @map("student_answer_order")
  correctAnswerOrder    Int?              @map("correct_answer_order")
  isCorrect             Boolean           @default(false) @map("is_correct")
  markedForReview       Boolean           @default(false) @map("marked_for_review")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  result StudentSimulationResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  question Question? @relation(fields: [questionId], references: [id], onDelete: SetNull)

  selectedAlternative Alternative? @relation("SelectedAlternativeOnStudentAnswer", fields: [selectedAlternativeId], references: [id], onDelete: SetNull)

  correctAlternative Alternative? @relation("CorrectAlternativeOnStudentAnswer", fields: [correctAlternativeId], references: [id], onDelete: SetNull)

  @@index([resultId])
  @@index([questionId])
  @@index([selectedAlternativeId])
  @@index([correctAlternativeId])
  @@map("student_simulation_answers")
}

/**
 * npx prisma validate      → confere se o schema está válido
 * npx prisma format        → organiza o schema.prisma
 * npx prisma migrate dev   → cria/atualiza tabelas no banco com histórico
 * npx prisma generate      → gera o client usado pelo backend
 * npx prisma studio        → abre painel visual do banco
 * npx prisma db push       → empurra schema para banco sem migration
 * npx prisma db pull       → puxa banco existente para o schema
 */
