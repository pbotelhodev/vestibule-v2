generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  TEACHER
  INSTITUTION
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  DELETED
}

enum AuthProvider {
  GOOGLE
  LOCAL
}

enum StudentType {
  INDIVIDUAL
  INSTITUTIONAL
}

/**
 * Schemas db
 */

/**
 * Schema User
 */

model User {
  id              String       @id @default(uuid())
  name            String
  email           String       @unique
  passwordHash    String?      @map("password_hash")
  role            UserRole     @default(STUDENT)
  status          UserStatus   @default(ACTIVE)
  authProvider    AuthProvider @default(LOCAL) @map("auth_provider")
  googleId        String?      @unique @map("google_id")
  studentType     StudentType  @default(INDIVIDUAL) @map("student_type")
  institutionCode String?      @map("institution_code")
  avatarUrl       String?      @map("avatar_url")
  phone           String?
  emailVerifiedAt DateTime?    @map("email_verified_at")
  lastLoginAt     DateTime?    @map("last_login_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@map("users")
}

/**
 * Schema Simulations
 */

enum SimulationSubject {
  MATEMATICA
  LINGUAS
  PORTUGUES
  LITERATURA
  INGLES
  ESPANHOL
  ARTES
  HISTORIA
  GEOGRAFIA
  BIOLOGIA
  FISICA
  QUIMICA
  CIENCIAS_HUMANAS
  CIENCIAS_NATUREZA
  GERAL
}

enum RequiredPlan {
  FREE
  PRO
  PREMIUM
}

model Simulation {
  id              String            @id @default(uuid())
  publicId        String            @unique @map("public_id")
  title           String
  description     String
  subject         SimulationSubject
  originCode      String            @default("vest") @map("origin_code")
  requiredPlan    RequiredPlan      @default(FREE) @map("required_plan")
  timePerQuestion Int               @map("time_per_question")
  isPublished     Boolean           @default(false) @map("is_published")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  questions       Question[]

  @@map("simulations")
}
model Question {
  id           String @id @default(uuid())
  simulationId String @map("simulation_id")

  statement    String
  imageUrl     String? @map("image_url")
  imageAlt     String? @map("image_alt")
  imageCaption String? @map("image_caption")

  subject      SimulationSubject
  topic        String?
  order        Int

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  
  alternatives Alternative[]

  @@map("questions")
}

model Alternative {
  id         String @id @default(uuid())
  questionId String @map("question_id")

  text       String?
  imageUrl   String? @map("image_url")
  imageAlt   String? @map("image_alt")
  isCorrect  Boolean @default(false) @map("is_correct")
  order      Int

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("alternatives")
}
/**
 * npx prisma validate      → confere se o schema está válido
 * npx prisma format        → organiza o schema.prisma
 * npx prisma migrate dev   → cria/atualiza tabelas no banco com histórico
 * npx prisma generate      → gera o client usado pelo backend
 * npx prisma studio        → abre painel visual do banco
 * npx prisma db push       → empurra schema para banco sem migration
 * npx prisma db pull       → puxa banco existente para o schema
 */
